GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL of the web app (used for OAuth redirect)
APP_URL=http://localhost:3000
# API listen port
API_PORT=4000
# Chatbot (extra credit)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
